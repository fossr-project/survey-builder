    ns1:id "23"^^xsd:int .

<https://w3id.org/fossr/data/questionGroup_23_name> a ns1:Name ;
    ns1:nameText "Fiducia" .

<https://w3id.org/fossr/data/questionGroup_24_content> a ns1:Content ;
    ns1:text "nan" .

<https://w3id.org/fossr/data/questionGroup_24_identifier> a ns1:Identifier ;
    ns1:id "24"^^xsd:int .

<https://w3id.org/fossr/data/questionGroup_24_name> a ns1:Name ;
    ns1:nameText "Orientamenti politici" .

<https://w3id.org/fossr/data/questionGroup_25_content> a ns1:Content ;
    ns1:text "<p><b>Desideriamo infine porle alcune domande su questa indagine. La sua opinione è molto importante per migliorare la qualità del questionario e la buona riuscita della ricerca. In che misura è d’accordo con le seguenti affermazioni? Per ogni affermazione è possibile fornire solo una risposta.</b></p>  <p><i>Con indagine demoscopica intendiamo ad esempio la ricerca che stiamo svolgendo con la somministrazione di questo questionario.</i></p>" .

