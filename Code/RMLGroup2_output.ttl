<https://w3id.org/fossr/data/questionGroup_22_content> a ns1:Content ;
    ns1:text "<span style=\"font-size:11.0pt\"><span style=\"line-height:115%\"><span style=\"font-family:&quot;Segoe UI&quot;,sans-serif\">Di seguito, si riportano alcune domande che rappresentano un buon esempio di quelle che potrebbe trovare all’interno del panel IOPP. Abbracciano un’ampia gamma di argomenti utili a comprendere le modalità di risposta e le finalità dell’indagine.</span></span></span>" .

<https://w3id.org/fossr/data/questionGroup_22_identifier> a ns1:Identifier ;
    ns1:id "22"^^xsd:int .

<https://w3id.org/fossr/data/questionGroup_22_name> a ns1:Name ;
    ns1:nameText "Valori" .

