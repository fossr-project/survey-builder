###############################################################
# SPARQL Queries for the LimeSurvey Ontology
# Prefix: https://w3id.org/fossr/ontology/limesurvey/
# Tested against: abox_test.ttl
###############################################################

@prefix : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl> .

###############################################################
# SECTION 1 — Survey Structure
###############################################################

# CQ1 — What surveys are associated with a specific study?
# Returns all Survey instances linked to a given Study via :hasInstrument.

PREFIX : <hhttps://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?study ?survey
WHERE {
    ?study a :Study .
    ?study :hasInstrument ?survey .
}

# To filter by a specific study, add:
# FILTER(?study = <YOUR_STUDY_URI>)

# ---------------------------------------------------------------

# CQ2 — What are the different versions of a particular survey?
# Returns all SurveyVersion instances linked to each Survey.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?survey ?version
WHERE {
    ?survey a :Survey .
    ?survey :hasSurveyVersion ?version .
}

# ---------------------------------------------------------------

# CQ3 — Which survey version was a particular version derived from?
# Traverses the :derivedFrom chain (transitive) to show version history.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?version ?derivedFrom
WHERE {
    ?version a :SurveyVersion .
    ?version :derivedFrom ?derivedFrom .
}

# For full transitive lineage (using :derivedFrom which is declared owl:TransitiveProperty):
# SPARQL 1.1 property path:
#
# SELECT ?version ?ancestor
# WHERE {
#     ?version a :SurveyVersion .
#     ?version :derivedFrom+ ?ancestor .
# }

# ---------------------------------------------------------------

# CQ4 — What is the recurrent time period for longitudinal surveys?
# Returns the :RecurrentTimePeriod associated with each Survey.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?survey ?period ?label
WHERE {
    ?survey a :Survey .
    ?survey :hasRecurrentTimePeriod ?period .
    OPTIONAL { ?period rdfs:label ?label . }
}

# ---------------------------------------------------------------

# CQ5 — What are the start and end dates for each collection period?
# Returns start and end times of each SurveyVersion's TimeInterval.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?version ?start ?end
WHERE {
    ?version a :SurveyVersion .
    ?version :hasIntervalValidity ?interval .
    ?interval :startTime ?start .
    OPTIONAL { ?interval :endTime ?end . }
}
ORDER BY ?start

###############################################################
# SECTION 2 — Survey Components
###############################################################

# CQ6 — What components does a survey contain?
# Returns all QuestionGroups reachable from a Survey through its GroupFlow.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT DISTINCT ?survey ?version ?group
WHERE {
    ?survey a :Survey .
    ?survey :hasSurveyVersion ?version .
    ?version :hasGroupFlow ?gf .
    ?gf :hasComponentFlowStep ?step .
    ?step :hasQuestionGroup ?group .
}

# ---------------------------------------------------------------

# CQ7 — What is the order of components within a survey?
# Returns each GroupFlowStep with its numeric order value.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?flow ?step ?group ?orderVal
WHERE {
    ?flow a :GroupFlow .
    ?flow :hasComponentFlowStep ?step .
    OPTIONAL { ?step :hasQuestionGroup ?group . }
    OPTIONAL {
        ?step :hasOrder ?ord .
        ?ord :order ?orderVal .
    }
}
ORDER BY ?flow ?orderVal

# ---------------------------------------------------------------

# CQ8 — What are the identifiers associated with each survey component?
# Returns all components with their Identifier and numeric id value.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?component ?type ?id ?idVal
WHERE {
    ?component :hasId ?id .
    ?id :id ?idVal .
    OPTIONAL { ?component a ?type . }
}
ORDER BY ?type ?idVal

# ---------------------------------------------------------------

# CQ9 — What attributes does a specific component have?
# Returns all ComponentAttribute instances linked to each component.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?component ?attr ?name ?value
WHERE {
    ?component :hasComponentAttribute ?attr .
    ?attr :componentName ?name .
    ?attr :componentValue ?value .
}

# ---------------------------------------------------------------

# CQ10 — What is the name and value of a component attribute?
# Returns all ComponentAttribute instances with their name/value pair.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?attr ?name ?value
WHERE {
    ?attr a :ComponentAttribute .
    ?attr :componentName ?name .
    ?attr :componentValue ?value .
}
ORDER BY ?name

###############################################################
# SECTION 3 — Questions, Question Groups and Answer Options
###############################################################

# CQ11 — What questions belong to a specific question group?
# Returns all Question instances linked to each QuestionGroup.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?group ?groupName ?question ?questionText
WHERE {
    ?group a :QuestionGroup .
    ?group :hasQuestion ?question .
    OPTIONAL {
        ?group :hasName ?n .
        ?n :nameText ?groupName .
    }
    OPTIONAL {
        ?question :hasContent ?c .
        ?c :text ?questionText .
    }
}

# ---------------------------------------------------------------

# CQ12 — What is the condition (relevance) for displaying a question group or question?
# Returns the relevance expression associated with each GroupFlowStep or QuestionStep.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

# For question groups (GroupFlowStep):
SELECT ?step ?groupOrQuestion ?relevanceExpr
WHERE {
    {
        ?step a :GroupFlowStep .
        ?step :hasQuestionGroup ?groupOrQuestion .
    } UNION {
        ?step a :QuestionStep .
    }
    ?step :hasCondition ?rel .
    ?rel :relevance ?relevanceExpr .
}

# ---------------------------------------------------------------

# CQ13 — What answer options are available for a given question?
# Returns all AnswerOption instances with text and order for each Question.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?answerOption ?code ?text ?order
WHERE {
    ?question a :Question .
    ?question :hasAnswerOption ?answerOption .
    ?answerOption :componentValue ?code .
    OPTIONAL { ?answerOption :answerText ?text . }
    OPTIONAL { ?answerOption :answerOrder ?order . }
}
ORDER BY ?question ?order

# ---------------------------------------------------------------

# CQ14 — What answer options are available for a given question group?
# Navigates from QuestionGroup → Question → AnswerOption.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?group ?question ?answerOption ?text ?order
WHERE {
    ?group a :QuestionGroup .
    ?group :hasQuestion ?question .
    ?question :hasAnswerOption ?answerOption .
    OPTIONAL { ?answerOption :answerText ?text . }
    OPTIONAL { ?answerOption :answerOrder ?order . }
}
ORDER BY ?group ?question ?order

# ---------------------------------------------------------------

# CQ15 — What is the default value for a specific question?
# Returns the :DefaultValue content linked to each Question.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?defaultContent
WHERE {
    ?question a :Question .
    ?question :hasDefaultValue ?dv .
    ?dv :defaultValueContent ?defaultContent .
}

# ---------------------------------------------------------------

# CQ16 — What type does a question have?
# Returns the QuestionType code associated with each Question.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?questionType ?typeCode
WHERE {
    ?question a :Question .
    ?question :hasType ?questionType .
    ?questionType :componentValue ?typeCode .
}

# ---------------------------------------------------------------

# CQ17 — What variable is associated with a question?
# Returns the Variable and its code for each Question.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?variable ?variableCode
WHERE {
    ?question a :Question .
    ?question :hasVariable ?variable .
    ?variable :variableCod ?variableCode .
}

# ---------------------------------------------------------------

# CQ18 — Does a question have subquestions, and if so, what are they?
# Returns all Subquestion instances linked to each Question.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?subquestion
WHERE {
    ?question a :Question .
    ?question :hasSubquestion ?subquestion .
}

# ---------------------------------------------------------------

# CQ19 — What is the order of answer options for a question or question group?
# Returns answer options ordered by :answerOrder.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?answerOption ?code ?text ?orderVal
WHERE {
    ?question a :Question .
    ?question :hasAnswerOption ?answerOption .
    ?answerOption :componentValue ?code .
    OPTIONAL { ?answerOption :answerText ?text . }
    OPTIONAL { ?answerOption :answerOrder ?orderVal . }
}
ORDER BY ?question ?orderVal

###############################################################
# SECTION 4 — Variables and Data Collection
###############################################################

# CQ20 — What variable name is associated with each question?
# Returns the variable code (:variableCod) for each Question.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT ?question ?questionText ?variableCode
WHERE {
    ?question a :Question .
    ?question :hasVariable ?v .
    ?v :variableCod ?variableCode .
    OPTIONAL {
        ?question :hasContent ?c .
        ?c :text ?questionText .
    }
}

# ---------------------------------------------------------------

# CQ21 — What variables are collected in a survey?
# Navigates the full chain Survey → SurveyVersion → GroupFlow →
# GroupFlowStep → QuestionGroup → Question → Variable.

PREFIX : <https://anonymous.4open.science/r/survey-builder-8232/ontology/limesurvey.ttl>

SELECT DISTINCT ?survey ?variableCode
WHERE {
    ?survey a :Survey .
    ?survey :hasSurveyVersion ?sv .
    ?sv :hasGroupFlow ?gf .
    ?gf :hasComponentFlowStep ?gfs .
    ?gfs :hasQuestionGroup ?qg .
    ?qg :hasQuestion ?q .
    ?q :hasVariable ?v .
    ?v :variableCod ?variableCode .
}
ORDER BY ?survey ?variableCode
