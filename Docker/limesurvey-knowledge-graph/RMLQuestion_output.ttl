<https://w3id.org/fossr/data/question_333_identifier> a ns1:Identifier ;
    ns1:id "333"^^xsd:int .

<https://w3id.org/fossr/data/question_334_content> a ns1:Content ;
    ns1:text "È probabile che un bambino in età pre-scolare soffra se sua madre lavora" .

<https://w3id.org/fossr/data/question_334_identifier> a ns1:Identifier ;
    ns1:id "334"^^xsd:int .

<https://w3id.org/fossr/data/question_335_content> a ns1:Content ;
    ns1:text "Va bene lavorare, ma ciò che la maggior parte delle donne vuole veramente è una casa e dei figli" .

<https://w3id.org/fossr/data/question_335_identifier> a ns1:Identifier ;
    ns1:id "335"^^xsd:int .

<https://w3id.org/fossr/data/question_336_content> a ns1:Content ;
    ns1:text "Un padre che lavora dovrebbe usufruire del congedo parentale per prendersi cura dei suoi figli" .

<https://w3id.org/fossr/data/question_336_identifier> a ns1:Identifier ;
    ns1:id "336"^^xsd:int .

<https://w3id.org/fossr/data/question_337_content> a ns1:Content ;
    ns1:text "Uomini e donne devono contribuire equamente nel prendersi cura dei propri figli" .

<https://w3id.org/fossr/data/question_337_identifier> a ns1:Identifier ;
    ns1:id "337"^^xsd:int .

<https://w3id.org/fossr/data/question_338_content> a ns1:Content ;
    ns1:text "Lei ritiene che si possa avere fiducia nella maggior parte delle persone, o che sia meglio essere diffidenti? Indichi la sua opinione utilizzando una scala da 0 a 10, dove 0 rappresenta la necessità di essere diffidenti e 10 rappresenta la possibilità di fidarsi." .

<https://w3id.org/fossr/data/question_338_identifier> a ns1:Identifier ;
    ns1:id "338"^^xsd:int .

<https://w3id.org/fossr/data/question_339_content> a ns1:Content ;
