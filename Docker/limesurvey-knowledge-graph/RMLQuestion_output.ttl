    ns1:id "281"^^xsd:int .

<https://w3id.org/fossr/data/question_282_content> a ns1:Content ;
    ns1:text "Lei ha lasciato senza risposta questa domanda. Potrebbe dirci perché non ha risposto?" .

<https://w3id.org/fossr/data/question_282_identifier> a ns1:Identifier ;
    ns1:id "282"^^xsd:int .

<https://w3id.org/fossr/data/question_283_content> a ns1:Content ;
    ns1:text "Lei ha lasciato senza risposta questa domanda. Potrebbe dirci perché non ha risposto?" .

<https://w3id.org/fossr/data/question_283_identifier> a ns1:Identifier ;
    ns1:id "283"^^xsd:int .

<https://w3id.org/fossr/data/question_284_content> a ns1:Content ;
    ns1:text "<p>La sua partecipazione al panel IOPP è un contributo prezioso per la ricerca sociale. Al momento ha indicato di non voler aderire all’indagine, ma ci farebbe piacere offrirle ulteriori informazioni sui benefici e sull’importanza della partecipazione.</p> <p>Sarebbe disponibile a essere contattato per approfondire questi aspetti?</p>" .

<https://w3id.org/fossr/data/question_284_identifier> a ns1:Identifier ;
    ns1:id "284"^^xsd:int .

<https://w3id.org/fossr/data/question_285_content> a ns1:Content ;
